;\n    }, [])\n    const handleScroll = () => {\n        if(window.scrollY > 120) {\n            setState(true); \n        } else {\n            setState(false);\n        }\n    }\n  return (\n    <>\n      <Navbar variant=\"light\" expand=\"lg\" className={`navbar ${state ? 'bgShadow' : 'navbar'} `}>\n        <Container>\n          <Navbar.Brand >\n            <div className=\"nav-logo\">\n              <h3 className=\"mx-1\">Emeka</h3>\n              <div className=\"logo-square\"></div>\n            </div>\n          </Navbar.Brand>\n          <Navbar.Toggle aria-controls=\"navbarScroll\" className=\"custom-toggler\" />\n          <Navbar.Collapse id=\"navbarScroll\">\n            <Nav className=\"ms-auto navbarFlex\">\n              <Nav.Link to=\"/\" className=\"nav-link\">about</Nav.Link>\n              <Nav.Link className=\"nav-link\">projects</Nav.Link>\n              <Nav.Link className=\"nav-link\">contact</Nav.Link>\n              <Nav.Link className=\"\">\n              <Button className=\"btn-green\">resume</Button>\n              </Nav.Link>\n            </Nav>\n          </Navbar.Collapse>\n        </Container>\n      </Navbar>\n    </>\n  );\n};\n\nexport default Header;\n","import \"../Footer/Footer.scss\";\nimport \"bootstrap/dist/css/bootstrap.min.css\";\nimport { Button } from \"react-bootstrap\";\nimport { ImGithub } from \"react-icons/im\";\nimport { AiOutlineBehance, AiFillLinkedin } from \"react-icons/ai\";\n\nconst Footer = () => {\n  return (\n    <div className=\"footer p-2 pt-5\">\n      <div className=\"footer__container\">\n        <div className=\"footer__header\">\n          <h3>Get In Touch</h3>\n        </div>\n        <div className=\"footer__desc\">\n          <p className=\"text-skyblue\">\n            Meeting amazing people is one of the greatest things in life. Feel\n            free to get in touch!\n          </p>\n        </div>\n        <div className=\"footer__cta\">\n          <Button className=\"app__hero__cta btn-green 